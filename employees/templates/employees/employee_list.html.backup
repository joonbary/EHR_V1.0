{% extends 'base_modern.html' %}
{% load static %}

{% block title %}직원 목록 - OK금융그룹 e-HR{% endblock %}

{% block content %}
<!-- 브레드크럼 -->
<nav class="flex mb-4" aria-label="Breadcrumb">
    <ol class="inline-flex items-center space-x-1 md:space-x-3">
        <li class="inline-flex items-center">
            <a href="{% url 'home' %}" class="inline-flex items-center text-sm font-medium text-gray-700 hover:text-primary dark:text-gray-400 dark:hover:text-white">
                <i class="fas fa-home mr-2"></i>
                홈
            </a>
        </li>
        <li>
            <div class="flex items-center">
                <i class="fas fa-chevron-right text-gray-400 mx-2"></i>
                <span class="ml-1 text-sm font-medium text-gray-500 md:ml-2 dark:text-gray-400">직원 목록</span>
            </div>
        </li>
    </ol>
</nav>

<!-- 페이지 헤더 -->
<div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between">
    <div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">직원 정보 관리</h1>
        <p class="text-gray-600 dark:text-gray-300">AI 기반 인재 분석으로 최적의 인력 배치와 육성 전략을 수립합니다</p>
    </div>
    <div class="mt-4 md:mt-0">
        <a href="{% url 'employees:employee_create' %}" class="btn btn-primary">
            <i class="fas fa-plus mr-2"></i>
            새 직원 등록
        </a>
    </div>
</div>

<!-- 검색 영역 -->
<div class="mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6">
        <form method="get" action="{% url 'employees:employee_list' %}">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">검색 유형</label>
                    <select name="search_type" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="all" {% if search_type == 'all' %}selected{% endif %}>전체</option>
                        <option value="name" {% if search_type == 'name' %}selected{% endif %}>이름</option>
                        <option value="department" {% if search_type == 'department' %}selected{% endif %}>부서</option>
                        <option value="position" {% if search_type == 'position' %}selected{% endif %}>직급</option>
                        <option value="email" {% if search_type == 'email' %}selected{% endif %}>이메일</option>
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">검색어</label>
                    <input type="text" name="q" 
                           placeholder="검색어를 입력하세요..." 
                           value="{{ search_query }}"
                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-primary focus:border-transparent">
                </div>
                <div class="flex items-end gap-2">
                    <button type="submit" class="btn btn-primary flex-1">
                        <i class="fas fa-search mr-2"></i>
                        검색
                    </button>
                    {% if search_query %}
                    <a href="{% url 'employees:employee_list' %}" class="btn btn-ghost">
                        <i class="fas fa-times"></i>
                    </a>
                    {% endif %}
                </div>
            </div>
        </form>
        
        {% if search_query %}
        <div class="mt-4 p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <p class="text-sm text-gray-600 dark:text-gray-300">
                <i class="fas fa-info-circle mr-2"></i>
                "<span class="font-semibold text-gray-900 dark:text-white">{{ search_query }}</span>" 검색 결과: <span class="font-semibold text-primary">{{ queryset_count }}</span>명
            </p>
        </div>
        {% endif %}
    </div>
</div>

<!-- 콘텐츠 영역 -->
<div>
    {% if employees %}
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
            <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                    <h3 class="text-lg font-semibold text-gray-900 dark:text-white">전체 직원 ({{ total_count }}명)</h3>
                    <div class="flex gap-2 mt-2 md:mt-0">
                        <a href="{% url 'employees:employee_bulk_upload' %}" class="btn btn-ghost btn-sm">
                            <i class="fas fa-upload mr-2"></i>
                            일괄 등록
                        </a>
                        <a href="{% url 'employees:employee_download_template' %}" class="btn btn-ghost btn-sm">
                            <i class="fas fa-download mr-2"></i>
                            템플릿
                        </a>
                    </div>
                </div>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                이름
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                이메일
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                부서
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                직급
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                성장레벨
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                입사일
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                전화번호
                            </th>
                            <th scope="col" class="relative px-6 py-3">
                                <span class="sr-only">작업</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        {% for employee in employees %}
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10">
                                        <div class="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center">
                                            <i class="fas fa-user text-primary"></i>
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <a href="{% url 'employees:employee_detail' employee.pk %}" 
                                           class="text-sm font-medium text-gray-900 dark:text-white hover:text-primary dark:hover:text-primary-light">
                                            {{ employee.name }}
                                        </a>
                                        {% if employee.employment_status != '재직' %}
                                            <span class="ml-2 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">
                                                {{ employee.get_employment_status_display }}
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <a href="mailto:{{ employee.email }}" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary">
                                    {{ employee.email }}
                                </a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-primary-light text-primary">
                                    {{ employee.get_department_display }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                {{ employee.get_position_display }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200">
                                    Level {{ employee.growth_level }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                {{ employee.hire_date|date:"Y-m-d" }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <a href="tel:{{ employee.phone }}" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary">
                                    {{ employee.phone }}
                                </a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{% url 'employees:employee_detail' employee.pk %}" 
                                       class="text-gray-600 hover:text-primary dark:text-gray-400 dark:hover:text-primary-light"
                                       title="상세보기">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{% url 'employees:employee_update' employee.pk %}" 
                                       class="text-gray-600 hover:text-primary dark:text-gray-400 dark:hover:text-primary-light"
                                       title="수정">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="{% url 'employees:employee_delete' employee.pk %}" 
                                       class="text-gray-600 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400"
                                       title="삭제"
                                       onclick="return confirm('정말로 이 직원을 삭제하시겠습니까?')">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- 페이지네이션 -->
            {% if is_paginated %}
            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-700">
                <nav class="flex items-center justify-between">
                    <div class="flex-1 flex justify-between sm:hidden">
                        {% if page_obj.has_previous %}
                            <a href="?page={{ page_obj.previous_page_number }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                               class="btn btn-ghost btn-sm">
                                이전
                            </a>
                        {% else %}
                            <span class="btn btn-ghost btn-sm opacity-50 cursor-not-allowed">이전</span>
                        {% endif %}
                        
                        {% if page_obj.has_next %}
                            <a href="?page={{ page_obj.next_page_number }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                               class="btn btn-ghost btn-sm ml-3">
                                다음
                            </a>
                        {% else %}
                            <span class="btn btn-ghost btn-sm ml-3 opacity-50 cursor-not-allowed">다음</span>
                        {% endif %}
                    </div>

                    
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-700 dark:text-gray-300">
                                <span class="font-medium">{{ page_obj.start_index }}</span>
                                -
                                <span class="font-medium">{{ page_obj.end_index }}</span>
                                / 총
                                <span class="font-medium">{{ page_obj.paginator.count }}</span>
                                건
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                {% if page_obj.has_previous %}
                                    <a href="?page=1{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                                       class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <span class="sr-only">처음</span>
                                        <i class="fas fa-angle-double-left"></i>
                                    </a>
                                    <a href="?page={{ page_obj.previous_page_number }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                                       class="relative inline-flex items-center px-2 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <span class="sr-only">이전</span>
                                        <i class="fas fa-angle-left"></i>
                                    </a>
                                {% endif %}
                                
                                {% for page_num in page_obj.paginator.page_range %}
                                    {% if page_num >= page_obj.number|add:-2 and page_num <= page_obj.number|add:2 %}
                                        {% if page_obj.number == page_num %}
                                            <span class="relative inline-flex items-center px-4 py-2 border border-primary bg-primary-light text-sm font-medium text-primary">
                                                {{ page_num }}
                                            </span>
                                        {% else %}
                                            <a href="?page={{ page_num }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                                               class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700">
                                                {{ page_num }}
                                            </a>
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                                
                                {% if page_obj.has_next %}
                                    <a href="?page={{ page_obj.next_page_number }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                                       class="relative inline-flex items-center px-2 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <span class="sr-only">다음</span>
                                        <i class="fas fa-angle-right"></i>
                                    </a>
                                    <a href="?page={{ page_obj.paginator.num_pages }}{% if search_query %}&q={{ search_query }}&search_type={{ search_type }}{% endif %}" 
                                       class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-700">
                                        <span class="sr-only">마지막</span>
                                        <i class="fas fa-angle-double-right"></i>
                                    </a>
                                {% endif %}
                            </nav>
                        </div>
                    </div>
                </nav>
            </div>
            {% endif %}
        </div>
    {% else %}
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm">
            <div class="text-center py-12">
                <i class="fas fa-users text-6xl text-gray-300 dark:text-gray-600 mb-4"></i>
                <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-2">등록된 직원이 없습니다</h3>
                <p class="text-gray-500 dark:text-gray-400 mb-6">새로운 직원을 등록하여 시작해보세요.</p>
                <div class="flex gap-3 justify-center">
                    <a href="{% url 'employees:employee_create' %}" class="btn btn-primary">
                        <i class="fas fa-plus mr-2"></i>
                        첫 번째 직원 등록
                    </a>
                    <a href="{% url 'employees:employee_bulk_upload' %}" class="btn btn-ghost">
                        <i class="fas fa-upload mr-2"></i>
                        일괄 등록
                    </a>
                </div>
            </div>
        </div>
    {% endif %}
</div>

{% endblock %} 